<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Meorawr/wow-ui-schema/main/UI.xsd">
    <Include file="SettingControl.lua" />

	<Button name="ChatterySettingResetButtonTemplate" mixin="ChatterySettingResetButtonMixin" virtual="true">
		<Size x="20" y="20"/>

		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon" atlas="common-icon-undo" setAllPoints="true" rotation="-30"/>
			</Layer>
			<Layer level="BACKGROUND">
				<Texture parentKey="Glow" atlas="house-upgrade-bg-radial-glow-center" alpha="1.0" hidden="true">
					<Size x="60" y="60"/>
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>

		<Animations>
			<AnimationGroup parentKey="GlowAnim" looping="REPEAT" setToFinalAlpha="true">
				<Rotation childKey="Glow" duration="6" order="1" degrees="0">
					<Origin point="CENTER"/>
				</Rotation>
			</AnimationGroup>
			<AnimationGroup parentKey="MouseoverAnim" looping="NONE">
				<Scale parentKey="Scale" childKey="Icon" duration="0.25" fromScaleX="1.0" toScaleX="1.1" fromScaleY="1.0" toScaleY="1.1" smoothing="IN_OUT" />
				<Rotation parentKey="Rotation" childKey="Icon" duration="0.25" degrees="30" smoothing="IN_OUT">
					<Origin point="CENTER"/>
				</Rotation>
			</AnimationGroup>
			<AnimationGroup parentKey="ClickAnim" looping="NONE">
				<Scale childKey="Icon" duration="0.1" fromScaleX="1.1" toScaleX="0.9" fromScaleY="1.1" toScaleY="0.9" smoothing="IN_OUT"/>
			</AnimationGroup>
		</Animations>

		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave method="OnLeave"/>
			<OnMouseDown method="OnMouseDown"/>
			<OnMouseUp method="OnMouseUp"/>
			<OnClick method="OnClick"/>
		</Scripts>
	</Button>

    <Frame name="ChatterySettingContainerTemplate" mixin="ChatterySettingContainerMixin" virtual="true">
        <Animations>
            <AnimationGroup parentKey="Anim" inherits="ChatterySlideInAnimTemplate"/>
        </Animations>

		<Frames>
			<Button parentKey="ResetButton" inherits="ChatterySettingResetButtonTemplate">
				<Anchors>
					<Anchor point="RIGHT" x="16"/>
				</Anchors>
			</Button>
		</Frames>

        <Scripts>
			<OnLoad method="OnLoad"/>
            <OnShow method="OnShow"/>
            <OnHide method="OnHide"/>
        </Scripts>
    </Frame>

    <Frame name="ChatterySettingControlTemplate" mixin="ChatterySettingControlMixin" virtual="true">
        <Scripts>
			<OnLoad method="OnLoad"/>
            <OnShow method="OnShow"/>
            <OnHide method="OnHide"/>
        </Scripts>
    </Frame>

    <EditBox name="ChatterySettingControlEditboxTemplate" mixin="ChatterySettingControlEditboxMixin" inherits="ChatterySettingControlTemplate,InputBoxTemplate" autoFocus="false" virtual="true">
        <Size x="100" y="32"/>

        <Scripts>
            <OnTextChanged method="OnTextChanged"/>
            <OnEnterPressed method="OnEnterPressed"/>
        </Scripts>
    </EditBox>

    <CheckButton name="ChatterySettingControlCheckboxTemplate" mixin="ChatterySettingControlCheckboxMixin" inherits="ChatterySettingControlTemplate,UICheckButtonTemplate" virtual="true">
        <Scripts>
            <OnClick method="OnClick"/>
        </Scripts>
    </CheckButton>
</Ui>
