package-as: Chattery

license-output: LICENSE

ignore:
  - Libs/*/*.rockspec
  - Libs/*/*.toc
  - Libs/*/changelog.*
  - Libs/*/CHANGELOG.*
  - Libs/*/docs
  - Libs/*/examples
  - Libs/*/README.*
  - Libs/*/tests
  - Libs/*/.pkgmeta
  - CHANGELOG.md
  - README.md

externals:
  Libs/LibStub: https://repos.wowace.com/wow/libstub/trunk
  Libs/LibChatFilter: https://github.com/Ghostopheles/LibChatFilter
  Libs/LibDBIcon-1.0: https://repos.wowace.com/wow/libdbicon-1-0/trunk
  Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown
